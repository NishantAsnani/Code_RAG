# ==============================================================================
# 📦 1. GLOBAL DEPENDENCIES & PACKAGE MANAGERS
# ==============================================================================
node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==============================================================================
# 🌐 2. NEXT.JS FRONTEND ARTIFACTS
# ==============================================================================
# Next.js build outputs
**/.next/
**/out/

# General production build folders (used by Next or custom build scripts)
**/build/
**/dist/

# TypeScript incremental compilation cache
*.tsbuildinfo
**/next-env.d.ts

# Vercel deployment CLI metadata
.vercel

# ==============================================================================
# 🚀 3. NODE.JS BACKEND ARTIFACTS
# ==============================================================================
# Compiled backend code (if using TypeScript/Babel on the backend)
**/dist/
**/lib/

# Testing coverage reports
**/coverage/
.nyc_output/

# Log files generated by Node or process managers (like PM2)
*.log
**/logs/
pids/
*.pid
*.seed
*.pid.lock

# REPL history
.node_repl_history

# ==============================================================================
# 🔒 4. SECRETS & ENVIRONMENT VARIABLES (CRITICAL)
# ==============================================================================
# Blocks all local environment files in root, frontend, and backend
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env*.local
**/.env

# Local SSL certificates / Private keys
*.pem
*.key
**/*.pem
**/*.key

# ==============================================================================
# 💻 5. SYSTEM & IDE ARTIFACTS
# ==============================================================================
# Operating System files
.DS_Store
Thumbs.db
ehthumbs.db

# IDE settings (optional but recommended to keep repo clean)
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

chroma-data/